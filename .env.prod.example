DJANGO_ENV=prod
DJANGO_SECRET_KEY=replace-with-production-secret
DJANGO_ALLOWED_HOSTS=api.example.com

POSTGRES_DB=shoplane
POSTGRES_USER=shoplane_user
POSTGRES_PASSWORD=replace-with-production-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Required: set to your production frontend URL(s), comma-separated.
CORS_ALLOWED_ORIGINS=https://example.com

LOG_LEVEL=WARNING
DB_LOG_LEVEL=WARNING

SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
