DJANGO_ENV=staging
DJANGO_SECRET_KEY=replace-with-staging-secret
DJANGO_ALLOWED_HOSTS=staging.example.com

POSTGRES_DB=shoplane_staging
POSTGRES_USER=shoplane_user
POSTGRES_PASSWORD=replace-with-staging-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Required: set to your staging frontend URL(s), comma-separated.
CORS_ALLOWED_ORIGINS=https://staging.example.com
