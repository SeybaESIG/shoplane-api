DJANGO_ENV=dev
DJANGO_SECRET_KEY=your-secure-django-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=shoplane
POSTGRES_USER=shoplane_user
POSTGRES_PASSWORD=shoplane_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Comma-separated list of allowed frontend origins for CORS.
# Dev defaults to localhost:3000 and localhost:5173 if not set.
# Staging and prod require this to be set explicitly.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

REDIS_URL=redis://localhost:6379/0

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
DB_LOG_LEVEL=WARNING

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.0
